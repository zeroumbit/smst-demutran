# Variáveis de ambiente para o projeto
# Copie este arquivo para .env e preencha com suas credenciais
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# PWA: prefixo do subdomínio administrativo (ex: "admin.")
# Usado para redirecionar / → /admin/login no PWA admin
# Padrão: "admin." (funciona para admin.seudominio.com)
VITE_ADMIN_DOMAIN_PREFIX=admin.
